{
  "name": "yapp",
  "version": "1.0.0",
  "description": "Yapp - A modern messaging PWA",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --exclude 'tests/rules.test.ts'",
    "test:watch": "vitest",
    "test:rules": "vitest run tests/rules.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "backfill:yapp-indexes": "node scripts/backfill-yapp-indexes.mjs"
  },
  "dependencies": {
    "firebase": "^11.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.15.0",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^3.2.4"
  }
}
